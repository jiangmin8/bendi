# ============================================================
# Llama.cpp 推理服务环境配置
# 复制此文件为 .env 并根据需要修改
# cp .env.example .env
# ============================================================

# --------------------------------------------------
# Hugging Face 配置
# --------------------------------------------------
# Hugging Face 访问令牌（下载 gated 模型必需）
# 获取方式: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# --------------------------------------------------
# GPU 配置
# --------------------------------------------------
# 指定使用的 GPU (多 GPU 用逗号分隔: 0,1)
CUDA_VISIBLE_DEVICES=0

# GPU 卸载层数 (all=全部, 0=CPU  only, 具体数字=指定层数)
GPU_LAYERS=all

# --------------------------------------------------
# 服务配置
# --------------------------------------------------
# 服务监听端口
LLAMA_PORT=8080

# 最大上下文长度 (越大占用 VRAM 越多)
# 8192, 16384, 32768, 65536, 131072
CTX_SIZE=32768

# 批处理大小
BATCH_SIZE=2048

# Micro-batch 大小 (影响延迟)
UBATCH_SIZE=512

# 并发请求槽位数
PARALLEL=4

# HTTP 工作线程数
HTTP_THREADS=4

# Batch 处理线程数
BATCH_THREADS=4

# 请求超时时间（秒）
TIMEOUT=300

# API 认证密钥 (留空表示不启用认证)
# API_KEY=your-secret-api-key

# 启用 Flash Attention (减少 VRAM 使用)
# FLASH_ATTN=1

# --------------------------------------------------
# 监控配置
# --------------------------------------------------
# Prometheus 端口
PROMETHEUS_PORT=9090

# Grafana 端口
GRAFANA_PORT=3000

# Grafana 管理员账号
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Grafana 外部访问地址
GRAFANA_URL=http://localhost:3000

# --------------------------------------------------
# Nginx 配置 (可选)
# --------------------------------------------------
# HTTP 端口
NGINX_HTTP_PORT=80

# HTTPS 端口
NGINX_HTTPS_PORT=443

# --------------------------------------------------
# 容器仓库配置 (CI/CD 推送用)
# --------------------------------------------------
# REGISTRY=ghcr.io/your-org
# IMAGE_NAME=llama-server
# MODEL_TAG=latest
